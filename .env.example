# Copier vers .env.local et remplir. En self-hosted, l'installateur genere ce fichier.
#
# Deploiement Vercel: ajouter ces variables dans Settings > Environment Variables,
# cocher Production + Preview, puis redeployer (obligatoire pour NEXT_PUBLIC_*).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000
# Afficher les comptes de test sur /login (staging / demo)
# NEXT_PUBLIC_SHOW_TEST_ACCOUNTS=true
CONNECTIONS_ENCRYPTION_KEY=

# Session client final (cookie signe). Par defaut: CONNECTIONS_ENCRYPTION_KEY
# CLIENT_SESSION_SECRET=

# OpenAI — assistant IA (langage naturel). Optionnel : heuristiques FR sans clé.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Cron Vercel — bonus anniversaire fidélité (POST /api/cron/loyalty/birthday)
CRON_SECRET=
